{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.ai.check.request",
  "type": "object",
  "required": ["request_id", "source_name", "source"],
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "source_name": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "property_id": { "type": ["string", "null"] },
    "backend": {
      "type": ["string", "null"],
      "enum": ["explicit", "mock-bmc", "sat-varisat", "smt-cvc5", "command", null]
    },
    "solver_executable": { "type": ["string", "null"] },
    "solver_args": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
