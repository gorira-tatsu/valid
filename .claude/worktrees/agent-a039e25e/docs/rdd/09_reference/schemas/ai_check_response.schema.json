{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.ai.check.response",
  "oneOf": [
    {
      "type": "object",
      "required": ["kind", "manifest", "status", "assurance_level"],
      "properties": {
        "kind": { "const": "completed" },
        "manifest": { "type": "object" },
        "status": { "type": "string", "enum": ["PASS", "FAIL", "UNKNOWN"] },
        "assurance_level": {
          "type": "string",
          "enum": ["complete", "bounded", "incomplete"]
        },
        "property_result": { "type": "object" },
        "trace": { "type": ["object", "null"] }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["kind", "manifest", "status", "assurance_level", "diagnostics"],
      "properties": {
        "kind": { "const": "error" },
        "manifest": { "type": "object" },
        "status": { "const": "ERROR" },
        "assurance_level": { "const": "incomplete" },
        "diagnostics": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    }
  ]
}
