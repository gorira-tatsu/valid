{
  "mcpServers": {
    "valid-dsl": {
      "command": "/absolute/path/to/valid-mcp",
      "args": [
        "--model-file",
        "/absolute/path/to/model.valid"
      ],
      "env": {}
    },
    "valid-registry": {
      "command": "/absolute/path/to/valid-mcp",
      "args": [
        "--registry-binary",
        "/absolute/path/to/target/debug/examples/valid_models"
      ],
      "env": {}
    }
  }
}
