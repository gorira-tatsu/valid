{
  "mcpServers": {
    "valid-dsl": {
      "command": "valid",
      "args": [
        "mcp",
        "--model-file",
        "/absolute/path/to/model.valid"
      ],
      "env": {}
    },
    "valid-registry": {
      "command": "valid",
      "args": [
        "mcp",
        "--manifest-path",
        "/absolute/path/to/project/Cargo.toml"
      ],
      "env": {}
    }
  }
}
