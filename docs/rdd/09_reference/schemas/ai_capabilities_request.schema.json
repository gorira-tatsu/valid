{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Capabilities Request",
  "type": "object",
  "required": ["request_id"],
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "backend": {
      "type": "string",
      "enum": ["explicit", "mock-bmc", "command"]
    },
    "solver_executable": {
      "type": ["string", "null"]
    },
    "solver_args": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
