{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.ai.testgen.response",
  "type": "object",
  "required": ["schema_version", "request_id", "status", "vector_ids", "generated_files"],
  "properties": {
    "schema_version": { "type": "string" },
    "request_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["ok"] },
    "vector_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "generated_files": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
