{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.coverage_report",
  "type": "object",
  "required": ["schema_version", "model_id", "summary", "actions", "guards", "depth_histogram", "requirement_tags", "gate"],
  "properties": {
    "schema_version": { "type": "string" },
    "model_id": { "type": "string" },
    "summary": {
      "type": "object",
      "required": [
        "transition_coverage_percent",
        "business_transition_coverage_percent",
        "setup_transition_coverage_percent",
        "requirement_tag_coverage_percent",
        "decision_coverage_percent",
        "guard_full_coverage_percent",
        "business_guard_full_coverage_percent",
        "setup_guard_full_coverage_percent",
        "visited_state_count",
        "repeated_state_count",
        "step_count",
        "max_depth_observed"
      ],
      "properties": {
        "transition_coverage_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "business_transition_coverage_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "setup_transition_coverage_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "requirement_tag_coverage_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "decision_coverage_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "guard_full_coverage_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "business_guard_full_coverage_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "setup_guard_full_coverage_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "visited_state_count": { "type": "integer", "minimum": 0 },
        "repeated_state_count": { "type": "integer", "minimum": 0 },
        "step_count": { "type": "integer", "minimum": 0 },
        "max_depth_observed": { "type": "integer", "minimum": 0 }
      }
    },
    "requirement_tags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tag", "covered", "count"],
        "properties": {
          "tag": { "type": "string" },
          "covered": { "type": "boolean" },
          "count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action_id", "role", "covered", "count"],
        "properties": {
          "action_id": { "type": "string" },
          "role": { "type": "string", "enum": ["business", "setup"] },
          "covered": { "type": "boolean" },
          "count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "guards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action_id", "true_seen", "false_seen", "true_count", "false_count", "covered_both"],
        "properties": {
          "action_id": { "type": "string" },
          "true_seen": { "type": "boolean" },
          "false_seen": { "type": "boolean" },
          "true_count": { "type": "integer", "minimum": 0 },
          "false_count": { "type": "integer", "minimum": 0 },
          "covered_both": { "type": "boolean" }
        }
      }
    },
    "depth_histogram": { "type": "object" },
    "gate": {
      "type": "object",
      "required": ["schema_version", "status", "policy_id", "reasons"],
      "properties": {
        "schema_version": { "type": "string" },
        "status": { "type": "string", "enum": ["pass", "warn", "fail"] },
        "policy_id": { "type": "string" },
        "reasons": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
