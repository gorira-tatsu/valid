{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.ai.testgen.request",
  "type": "object",
  "required": ["request_id", "source_name", "source", "strategy"],
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "source_name": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "strategy": { "type": "string", "minLength": 1 },
    "backend": {
      "type": ["string", "null"],
      "enum": ["explicit", "mock-bmc", "smt-cvc5", "command", null]
    },
    "solver_executable": { "type": ["string", "null"] },
    "solver_args": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
