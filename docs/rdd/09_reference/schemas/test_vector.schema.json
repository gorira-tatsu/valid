{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.test_vector",
  "type": "object",
  "required": [
    "schema_version",
    "vector_id",
    "run_id",
    "source_kind",
    "strictness",
    "derivation",
    "strategy",
    "generator_version",
    "actions",
    "property_id",
    "minimized",
    "expected_path",
    "expected_path_tags",
    "setup_action_ids",
    "business_action_ids",
    "notes",
    "grouping"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "vector_id": { "type": "string" },
    "run_id": { "type": "string" },
    "source_kind": { "type": "string" },
    "strictness": { "type": "string" },
    "derivation": { "type": "string" },
    "evidence_id": { "type": ["string", "null"] },
    "strategy": { "type": "string" },
    "generator_version": { "type": "string" },
    "seed": { "type": ["integer", "null"] },
    "initial_state": { "type": ["object", "null"] },
    "actions": { "type": "array", "items": { "type": "object" } },
    "expected_observations": { "type": "array", "items": { "type": "object" } },
    "expected_states": { "type": "array", "items": { "type": "string" } },
    "property_id": { "type": "string" },
    "minimized": { "type": "boolean" },
    "focus_action_id": { "type": ["string", "null"] },
    "focus_field": { "type": ["string", "null"] },
    "expected_guard_enabled": { "type": ["boolean", "null"] },
    "expected_property_holds": { "type": ["boolean", "null"] },
    "expected_path": { "type": "array", "items": { "type": "string" } },
    "expected_path_tags": { "type": "array", "items": { "type": "string" } },
    "setup_action_ids": { "type": "array", "items": { "type": "string" } },
    "business_action_ids": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } },
    "grouping": {
      "type": "object",
      "required": ["requirement_clusters", "risk_clusters"],
      "properties": {
        "requirement_clusters": { "type": "array", "items": { "type": "string" } },
        "risk_clusters": { "type": "array", "items": { "type": "string" } }
      }
    },
    "replay_target": { "type": ["object", "null"] }
  }
}
