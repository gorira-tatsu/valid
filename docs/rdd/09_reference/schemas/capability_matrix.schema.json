{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.capability_matrix",
  "type": "object",
  "required": ["backend", "capabilities"],
  "properties": {
    "backend": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "object",
      "required": [
        "backend_name",
        "preferred",
        "builtin",
        "compiled_in",
        "available",
        "supports_explicit",
        "supports_bmc",
        "supports_certificate",
        "supports_trace",
        "supports_witness",
        "selfcheck_compatible",
        "selfcheck_status",
        "parity_status",
        "temporal"
      ],
      "properties": {
        "backend_name": { "type": "string", "minLength": 1 },
        "preferred": { "type": "boolean" },
        "builtin": { "type": "boolean" },
        "compiled_in": { "type": "boolean" },
        "available": { "type": "boolean" },
        "availability_reason": { "type": ["string", "null"] },
        "remediation": { "type": ["string", "null"] },
        "supports_explicit": { "type": "boolean" },
        "supports_bmc": { "type": "boolean" },
        "supports_certificate": { "type": "boolean" },
        "supports_trace": { "type": "boolean" },
        "supports_witness": { "type": "boolean" },
        "selfcheck_compatible": { "type": "boolean" },
        "selfcheck_status": { "type": "string", "minLength": 1 },
        "parity_status": { "type": "string", "minLength": 1 },
        "temporal": {
          "type": "object",
          "required": ["status", "semantics", "assurance_levels", "supported_operators", "unsupported_operators", "notes"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["complete", "bounded", "unavailable"]
            },
            "semantics": { "type": "string", "minLength": 1 },
            "assurance_levels": {
              "type": "array",
              "items": { "type": "string" }
            },
            "supported_operators": {
              "type": "array",
              "items": { "type": "string" }
            },
            "unsupported_operators": {
              "type": "array",
              "items": { "type": "string" }
            },
            "notes": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
